---
interface Props {
  /** 首页 Hero 覆盖模式：透明悬浮，滚动后变实色 */
  overlay?: boolean;
}
const { overlay = false } = Astro.props;

const nav = [
  { href: '/zhusu/', label: '找房源' },
  { href: '/daxue/', label: '看大学' },
  { href: '/guides/', label: '租房指南' },
  { href: '/about/', label: '关于' },
];
---

<header class:list={['us-header', overlay && 'us-header--overlay']} data-us-header data-overlay={overlay ? '1' : undefined}>
  <div class="us-wrap us-header__inner">
    <a href="/" class="us-header__brand" aria-label="UniStay 优住 首页">
      <img src="/favicon.svg" alt="" width="30" height="30" />
      <span class="us-header__brandname">UniStay 优住</span>
    </a>

    <nav class="us-nav" aria-label="主导航">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <button type="button" class="us-btn us-btn--primary us-btn--sm" onclick="window.usFindHome?.()">
        AI 帮我找房
      </button>
    </nav>

    <button
      type="button"
      class="us-burger"
      data-us-burger
      aria-label="打开菜单"
      aria-expanded="false"
      aria-controls="us-mobile-nav"
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

<div class="us-mnav" id="us-mobile-nav" data-us-mnav>
  {nav.map((n) => <a href={n.href}>{n.label}</a>)}
  <button type="button" class="us-btn us-btn--primary" onclick="window.usFindHome?.(); document.querySelector('[data-us-mnav]')?.classList.remove('is-open');">
    AI 帮我找房
  </button>
</div>

<script is:inline>
  (function () {
    function initHeader() {
      var header = document.querySelector('[data-us-header]');
      if (!header || header.dataset.usBound === '1') return;
      header.dataset.usBound = '1';

      var burger = document.querySelector('[data-us-burger]');
      var mnav = document.querySelector('[data-us-mnav]');
      if (burger && mnav) {
        burger.addEventListener('click', function () {
          var open = mnav.classList.toggle('is-open');
          burger.setAttribute('aria-expanded', open ? 'true' : 'false');
          burger.setAttribute('aria-label', open ? '关闭菜单' : '打开菜单');
        });
        mnav.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () {
            mnav.classList.remove('is-open');
            burger.setAttribute('aria-expanded', 'false');
          });
        });
      }

      if (header.dataset.overlay === '1') {
        var onScroll = function () {
          header.classList.toggle('is-scrolled', window.scrollY > 40);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    }
    document.addEventListener('astro:page-load', initHeader);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeader);
    } else {
      initHeader();
    }
  })();
</script>

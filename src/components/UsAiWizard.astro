---
// UsAiWizard.astro — 优住 AI 找房向导（中文 · 5 步 · 首页核心）
// 移植自 FindStay FsAiWizard，中文化 + 墨青/杏金配色（对齐 unistay 站 global.css tokens）
// 数据 lazy-load /wizard_cities.json（219 城 · 原生货币 · 数据驱动预算档）
// 留资 POST https://chat.unistay.cn/lead（与站内 lead.js 同库 + 顾问邮件）
---
<div class="usw" id="usw" data-usw-init="0">
  <div class="usw-tag"><span class="dot" aria-hidden="true"></span>AI 找房匹配 · 77 万条真实评价</div>
  <div class="usw-bar"><i id="uswBar"></i></div>
  <div id="uswView" class="usw-view"><div class="usw-load">正在准备房源…</div></div>
  <div class="usw-foot" id="uswFoot"><a href="#" id="uswChat">想直接问住宿小助手？→</a></div>
</div>

<style is:global>
.usw{background:#fff;border-radius:22px;box-shadow:0 30px 70px rgba(22,48,61,.28);overflow:hidden;max-width:460px;width:100%;text-align:left;color:#16303d;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif}
.usw-tag{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;color:#22485a;padding:16px 22px 0}
.usw-tag .dot{width:7px;height:7px;border-radius:50%;background:#c9873b;box-shadow:0 0 0 3px #f8efdf}
.usw-bar{height:4px;background:#e8eef1;margin-top:14px}
.usw-bar i{display:block;height:100%;width:20%;background:#22485a;transition:width .4s cubic-bezier(.2,.7,.3,1)}
.usw-view{min-height:230px}
.usw-load{padding:60px;text-align:center;color:#5a7079;font-size:14px}
.usw-body{padding:22px}
.usw-sh{display:flex;align-items:center;justify-content:space-between}
.usw-sn{font-weight:700;font-size:11.5px;letter-spacing:.1em;color:#22485a}
.usw-back{background:none;border:0;color:#5a7079;font-size:13px;cursor:pointer;font-family:inherit}
.usw-back:hover{color:#16303d}
.usw-q{font-weight:700;font-size:21px;letter-spacing:-.01em;margin:8px 0 16px;line-height:1.25}
.usw-srch{display:flex;align-items:center;gap:10px;border:1.5px solid #d7e0e4;border-radius:13px;padding:0 14px;height:50px;margin-bottom:12px}
.usw-srch:focus-within{border-color:#22485a;box-shadow:0 0 0 4px #e8eef1}
.usw-srch svg{width:18px;height:18px;color:#5a7079;flex:none}
.usw-srch input{border:0;outline:0;font:inherit;font-size:15px;width:100%;background:none}
.usw-chips{display:flex;flex-wrap:wrap;gap:7px}
.usw-chip{border:1.5px solid #d7e0e4;background:#fff;border-radius:999px;padding:7px 13px;font-size:13px;font-weight:600;cursor:pointer;color:#16303d}
.usw-chip:hover{border-color:#22485a;color:#22485a}
.usw-opts{display:grid;gap:9px}
.usw-opts.two{grid-template-columns:1fr 1fr}
.usw-opt{border:1.5px solid #d7e0e4;border-radius:13px;padding:13px 15px;cursor:pointer;background:#fff;text-align:left;font-family:inherit;display:flex;align-items:center;gap:11px;color:#16303d}
.usw-opt:hover{border-color:#22485a;background:#fafcfc}
.usw-opt .t{font-weight:700;font-size:14.5px}
.usw-opt .s{font-size:12px;color:#5a7079}
.usw-opt.ctr{justify-content:center;text-align:center;flex-direction:column;gap:2px;padding:13px 6px}
.usw-ta{width:100%;min-height:88px;border:1.5px solid #d7e0e4;border-radius:13px;padding:13px;font:inherit;font-size:14.5px;outline:0;resize:vertical}
.usw-ta:focus{border-color:#22485a;box-shadow:0 0 0 4px #e8eef1}
.usw-hints{display:flex;flex-wrap:wrap;gap:6px;margin-top:11px}
.usw-hint{background:#e8eef1;color:#22485a;border:0;border-radius:999px;padding:6px 11px;font-size:12px;font-weight:600;cursor:pointer}
.usw-cta{width:100%;height:50px;border:0;border-radius:13px;font-weight:700;font-size:15.5px;cursor:pointer;background:#22485a;color:#fff;box-shadow:0 8px 22px rgba(34,72,90,.3);margin-top:14px}
.usw-cta:hover{background:#16303d}
.usw-think{padding:48px 22px;text-align:center}
.usw-orb{width:60px;height:60px;margin:0 auto 18px;border-radius:50%;background:#e8eef1;position:relative}
.usw-orb::after{content:"";position:absolute;inset:-6px;border-radius:50%;border:3px solid #22485a;border-right-color:transparent;animation:uswspin .8s linear infinite}
@keyframes uswspin{to{transform:rotate(360deg)}}
.usw-think .t{font-weight:700;font-size:17px}
.usw-think .s{color:#5a7079;font-size:13.5px;margin-top:6px}
.usw-rh{padding:20px 20px 4px}
.usw-rh .lab{font-weight:700;font-size:11.5px;letter-spacing:.08em;color:#12805a}
.usw-rh h3{font-weight:700;font-size:18px;margin-top:6px;color:#16303d}
.usw-kb{font-size:11.5px;color:#22485a;background:#e8eef1;display:inline-block;padding:4px 10px;border-radius:8px;margin-top:9px;font-weight:600}
.usw-list{padding:12px 16px}
.usw-pc{display:flex;gap:12px;padding:10px;border-radius:14px;border:1px solid #edf1f2;margin-bottom:9px;text-decoration:none;color:inherit;transition:.15s}
.usw-pc:hover{border-color:#d7e0e4;box-shadow:0 8px 24px rgba(22,48,61,.08)}
.usw-pc .im{width:84px;height:84px;border-radius:11px;background:#e8eef1 center/cover;flex:none;position:relative}
.usw-pc .vb{position:absolute;top:5px;left:5px;background:rgba(255,255,255,.92);color:#12805a;font-size:9px;font-weight:700;padding:2px 6px;border-radius:999px}
.usw-pc h4{font-weight:700;font-size:15px;margin-bottom:3px;line-height:1.2}
.usw-pc .rt{font-size:12px;color:#5a7079;margin-bottom:5px}.usw-pc .rt b{color:#c9873b}
.usw-pc .why{font-size:11.5px;color:#22485a;background:#e8eef1;display:inline-block;padding:2px 8px;border-radius:7px;font-weight:600}
.usw-pc .pr{margin-left:auto;text-align:right;flex:none}
.usw-pc .pr b{font-weight:700;font-size:15.5px}
.usw-pc .pr s{display:block;font-size:10.5px;color:#5a7079;text-decoration:none}
.usw-lead{background:#16303d;color:#fff;padding:20px 22px}
.usw-lead h4{color:#fff;font-size:16px;font-weight:700;margin-bottom:3px}
.usw-lead p{color:rgba(255,255,255,.72);font-size:12.5px;margin-bottom:12px}
.usw-lf{display:flex;gap:8px;margin-bottom:8px}
.usw-lf input{flex:1;height:44px;border-radius:11px;border:0;padding:0 13px;font:inherit;font-size:14px;outline:0}
.usw-lead .usw-cta{margin-top:2px;background:#c9873b}
.usw-lead .usw-cta:hover{background:#a86d28}
.usw-err{color:#f4b78a;font-size:12px;margin-top:6px;display:none}
.usw-trust{text-align:center;font-size:11px;color:rgba(255,255,255,.5);margin-top:10px}
.usw-done{padding:46px 24px;text-align:center}
.usw-done .ck{width:60px;height:60px;border-radius:50%;background:#e7f4ee;display:grid;place-items:center;margin:0 auto 16px;color:#12805a;font-size:28px}
.usw-done h3{font-size:20px;font-weight:700}
.usw-done p{color:#5a7079;margin-top:8px;font-size:14px}
.usw-foot{padding:13px 22px;text-align:center;border-top:1px solid #edf1f2}
.usw-foot a{color:#22485a;font-size:13px;font-weight:600;text-decoration:none}
</style>

<script is:inline>
(function(){
  var root=document.getElementById('usw');
  if(!root||root.dataset.uswInit==='1')return; root.dataset.uswInit='1';
  var LEAD='https://chat.unistay.cn/lead', IMG='https://img.unistay.cn/';
  var view=document.getElementById('uswView'), bar=document.getElementById('uswBar');
  var chatLink=document.getElementById('uswChat');
  if(chatLink)chatLink.addEventListener('click',function(e){e.preventDefault();if(window.aiwOpen)window.aiwOpen();});
  var WZ=null, cityByName={}, unis=[], popular=[];
  var S={dest:'',destCity:null,budget:'',movein:'',room:'',notes:''};
  var esc=function(s){return String(s).replace(/[&<>"']/g,function(c){return{'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});};
  var setBar=function(p){bar.style.width=p+'%';};
  var fmtG=function(n){return (n||0).toLocaleString('en-US');};
  var cn=function(c){return (c&&(c.name_zh||c.name))||'';};
  var band=function(b){
    if(!b)return b;
    if(/^flexible$/i.test(b))return '预算灵活';
    var m=b.match(/^under\s+(.+)$/i); if(m)return '低于 '+m[1];
    var p=b.match(/^(.+?)\+$/); if(p)return p[1]+' 以上';
    return b;
  };

  fetch('/wizard_cities.json').then(function(r){return r.json();}).then(function(d){
    WZ=d;
    d.cities.forEach(function(c){cityByName[c.name.toLowerCase()]=c;});
    unis=d.unis||[];
    popular=d.cities.slice(0,6);
    step1();
  }).catch(function(){view.innerHTML='<div class="usw-load">找房功能即将开放，先<a href="/zhusu/" style="color:#22485a;font-weight:600">按城市浏览全部房源</a>。</div>';});

  function resolveCity(txt){
    var t=(txt||'').trim().toLowerCase(); if(!t)return null;
    if(cityByName[t])return cityByName[t];
    var u=unis.find(function(x){return x.n.toLowerCase()===t;}); if(u){var c=WZ.cities.find(function(y){return y.slug===u.c;});if(c)return c;}
    var partial=WZ.cities.find(function(c){return c.name.toLowerCase().indexOf(t)>=0 || cn(c).indexOf(t)>=0;}); if(partial)return partial;
    var pu=unis.find(function(x){return x.n.toLowerCase().indexOf(t)>=0;}); if(pu){var c2=WZ.cities.find(function(y){return y.slug===pu.c;});if(c2)return c2;}
    return null;
  }

  function step1(){setBar(20);
    var opts=WZ.cities.map(function(c){return '<option value="'+esc(cn(c))+'">';}).join('')+unis.map(function(u){return '<option value="'+esc(u.n)+'">';}).join('');
    view.innerHTML='<div class="usw-body"><div class="usw-sh"><span class="usw-sn">第 1 / 5 步</span></div>'+
      '<div class="usw-q">你要去哪里读书？</div>'+
      '<div class="usw-srch"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex:none"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5" stroke-linecap="round"/></svg>'+
      '<input id="uswDest" list="uswDL" placeholder="输入学校或城市…" autocomplete="off"/><datalist id="uswDL">'+opts+'</datalist></div>'+
      '<div class="usw-chips">'+popular.map(function(c){return '<button type="button" class="usw-chip" data-c="'+esc(cn(c))+'">'+esc(cn(c))+'</button>';}).join('')+'</div></div>';
    var inp=document.getElementById('uswDest');
    inp.addEventListener('change',function(){if(inp.value)go1(inp.value);});
    inp.addEventListener('keydown',function(e){if(e.key==='Enter'&&inp.value)go1(inp.value);});
    Array.prototype.forEach.call(view.querySelectorAll('.usw-chip'),function(b){b.addEventListener('click',function(){go1(b.dataset.c);});});
  }
  function go1(txt){var c=resolveCity(txt); if(!c){location.href='/zhusu/';return;} S.dest=txt; S.destCity=c; step2();}

  function step2(){setBar(40);var c=S.destCity;var o=(c.bands||[]).concat(['Flexible']);
    view.innerHTML='<div class="usw-body"><div class="usw-sh"><span class="usw-sn">第 2 / 5 步</span><button class="usw-back" data-b="1">‹ 返回</button></div>'+
      '<div class="usw-q">每周预算大概多少？</div>'+
      '<div class="usw-opts two">'+o.map(function(x){return '<button type="button" class="usw-opt" data-v="'+esc(x)+'"><span class="t">'+esc(band(x))+'</span></button>';}).join('')+'</div></div>';
    bindBack(step1); bindOpts(function(v){S.budget=v;step3();});
  }
  function step3(){setBar(60);var m=['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
    view.innerHTML='<div class="usw-body"><div class="usw-sh"><span class="usw-sn">第 3 / 5 步</span><button class="usw-back">‹ 返回</button></div>'+
      '<div class="usw-q">打算什么时候入住？</div>'+
      '<div class="usw-opts" style="grid-template-columns:repeat(4,1fr)">'+m.map(function(x){return '<button type="button" class="usw-opt ctr" data-v="'+x+' 2026"><span class="t">'+x+'</span><span class="s">2026</span></button>';}).join('')+'</div>'+
      '<button type="button" class="usw-opt" data-v="时间灵活" style="margin-top:9px;justify-content:center"><span class="t">入住时间灵活</span></button></div>';
    bindBack(step2); bindOpts(function(v){S.movein=v;step4();});
  }
  function step4(){setBar(80);var o=[['一室套间 Studio','独立房间 + 独立卫浴'],['独立单间','独立房间，共用卫浴'],['合租公寓','合租房里的一间'],['整套公寓','独享整套公寓']];
    view.innerHTML='<div class="usw-body"><div class="usw-sh"><span class="usw-sn">第 4 / 5 步</span><button class="usw-back">‹ 返回</button></div>'+
      '<div class="usw-q">想要哪种房型？</div>'+
      '<div class="usw-opts two">'+o.map(function(x){return '<button type="button" class="usw-opt" data-v="'+esc(x[0])+'"><span><span class="t">'+x[0]+'</span><span class="s">'+x[1]+'</span></span></button>';}).join('')+'</div></div>';
    bindBack(step3); bindOpts(function(v){S.room=v;step5();});
  }
  function step5(){setBar(100);var h=['离地铁/车站近','安静适合学习','附近有健身房','账单全包','可养宠物'];
    view.innerHTML='<div class="usw-body"><div class="usw-sh"><span class="usw-sn">第 5 / 5 步</span><button class="usw-back">‹ 返回</button></div>'+
      '<div class="usw-q">还有什么特别在意的？</div>'+
      '<p style="color:#5a7079;font-size:13.5px;margin:-8px 0 12px">用你自己的话告诉 AI——它会拿去和真实住客评价做匹配。选填。</p>'+
      '<textarea class="usw-ta" id="uswNotes" placeholder="例如：楼里安静、步行 10 分钟到校、带独卫和大书桌、附近有超市…"></textarea>'+
      '<div class="usw-hints">'+h.map(function(x){return '<button type="button" class="usw-hint" data-h="'+esc(x)+'">+ '+x+'</button>';}).join('')+'</div>'+
      '<button type="button" class="usw-cta" id="uswGo">帮我匹配房源 →</button></div>';
    bindBack(step4);
    Array.prototype.forEach.call(view.querySelectorAll('.usw-hint'),function(b){b.addEventListener('click',function(){var t=document.getElementById('uswNotes');t.value=(t.value?t.value.replace(/\s*$/,'')+'，':'')+b.dataset.h;t.focus();});});
    document.getElementById('uswGo').addEventListener('click',function(){S.notes=document.getElementById('uswNotes').value;think();});
  }
  function think(){var c=S.destCity;
    view.innerHTML='<div class="usw-think"><div class="usw-orb"></div><div class="t">正在为你匹配房源…</div>'+
      '<div class="s">'+(S.notes?'在 77 万条评价里搜索「'+esc(S.notes.slice(0,38))+(S.notes.length>38?'…':'')+'」':'正在筛选 '+esc(cn(c))+' 的已核实房源')+'</div></div>';
    setTimeout(results,1400);
  }
  function results(){var c=S.destCity;
    var cards=(c.props||[]).slice(0,3).map(function(p){
      var img=p.i?IMG+p.i:'';
      return '<a class="usw-pc" href="/fangyuan/'+p.s+'/"><div class="im" style="'+(img?'background-image:url(\''+img+'\')':'')+'"><span class="vb">✓ 已核实</span></div>'+
        '<div><h4>'+esc(p.n)+'</h4><div class="rt">'+(p.r?'<b>★ '+p.r+'</b> · ':'')+fmtG(p.g)+' 条谷歌评价</div></div>'+
        '<div class="pr"><b>'+c.cur+p.p.toLocaleString('en-US')+'</b><s>/周</s></div></a>';
    }).join('');
    view.innerHTML='<div class="usw-rh"><span class="lab">✓ 已核实匹配</span><h3>'+esc(S.dest)+' 附近的房源</h3>'+
      (S.notes?'<div class="usw-kb">✨ AI 已匹配：「'+esc(S.notes.slice(0,46))+(S.notes.length>46?'…':'')+'」</div>':'')+'</div>'+
      '<div class="usw-list">'+cards+'</div>'+
      '<div class="usw-lead"><h4>想让顾问帮你锁定一套？</h4>'+
      '<p>留个联系方式——住宿顾问会在一个工作日内帮你核实房态。免费，无预订费。</p>'+
      '<div class="usw-lf"><input id="uswName" placeholder="你的称呼"/><input id="uswContact" placeholder="邮箱或微信"/></div>'+
      '<button type="button" class="usw-cta" id="uswSend">获取房源清单 + 帮我锁房 →</button>'+
      '<div class="usw-err" id="uswErr">请留个邮箱或微信，方便顾问联系你。</div>'+
      '<div class="usw-trust">免费 · 信息只交给真人顾问，不外传</div></div>';
    document.getElementById('uswSend').addEventListener('click',submitLead);
  }
  function submitLead(){
    var name=document.getElementById('uswName').value.trim();
    var contact=document.getElementById('uswContact').value.trim();
    var err=document.getElementById('uswErr');
    if(!contact){err.style.display='block';return;}
    var isEmail=contact.indexOf('@')>0;
    var c=S.destCity;
    var notes='入住：'+S.movein+'。房型：'+S.room+'。预算：'+band(S.budget)+'。'+(S.notes?' 需求：'+S.notes:'');
    var payload={attribution:{site_id:'unistay-cn',page_url:location.href,channel:'wizard',lang:'zh'},
      lead:{name:name,intended_country:(c&&c.country)||'',target_school:S.dest,budget_cny:'',specific_questions:notes}};
    if(isEmail)payload.lead.email=contact; else payload.lead.phone=contact;
    var btn=document.getElementById('uswSend'); btn.textContent='提交中…'; btn.disabled=true;
    fetch(LEAD,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
      .then(function(){done();}).catch(function(){done();});
  }
  function done(){view.innerHTML='<div class="usw-done"><div class="ck">✓</div><h3>搞定！</h3>'+
    '<p>顾问会在一个工作日内联系你，带上房源清单和房态确认。</p></div>';}

  function bindBack(fn){var b=view.querySelector('.usw-back'); if(b)b.addEventListener('click',fn);}
  function bindOpts(fn){Array.prototype.forEach.call(view.querySelectorAll('.usw-opt'),function(b){b.addEventListener('click',function(){fn(b.dataset.v);});});}
})();
</script>

---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
}
const { entry } = Astro.props;
const date = (entry.data.publishDate || '').slice(0, 10);
---

<a href={`/${entry.id}/`} class="us-row us-reveal">
  <span class="us-row__name">{entry.data.title}</span>
  <span class="us-row__meta">{date}</span>
</a>

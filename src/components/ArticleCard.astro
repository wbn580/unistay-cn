---
import { classifyRegion, getRegionBySlug } from '../utils/region';

const { entry } = Astro.props as { entry: any };

// Classify region from title + body
const regionSlug = classifyRegion(
  entry.data.title,
  entry.body || '',
  entry.data.tags || []
);
const regionInfo = getRegionBySlug(regionSlug);
const regionLabel = regionInfo?.name || entry.data.category || '';
---

<a href={`/${entry.id}/`} class="card-link block bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-shadow border border-primary/10">
  {
    entry.data.heroImage ? (
      <img
        src={entry.data.heroImage}
        alt={entry.data.title}
        class="w-full h-48 object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-48 bg-slate-200 flex items-center justify-center text-slate-400 text-sm">无图</div>
    )
  }
  <div class="p-5">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-bold uppercase text-accent bg-accent/10 px-2 py-0.5 rounded">{regionLabel}</span>
    </div>
    <h3 class="font-heading text-lg text-primary line-clamp-2 leading-snug">{entry.data.title}</h3>
    <p class="text-sm text-muted mt-2 line-clamp-2">{entry.data.description}</p>
  </div>
</a>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { classifyRegion, getRegionBySlug } from '../../utils/region';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  // Collect unique regions from all articles
  const regionSet = new Set<string>();
  for (const a of articles) {
    const r = classifyRegion(a.data.title, a.body || '', a.data.tags || []);
    regionSet.add(r);
  }
  return Array.from(regionSet).map(slug => ({ params: { region: slug } }));
}

const { region } = Astro.params;
const regionInfo = getRegionBySlug(region as string);

const allEntries = await getCollection('articles');
const entries = allEntries
  .filter(e => classifyRegion(e.data.title, e.body || '', e.data.tags || []) === region)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const title = regionInfo ? `${regionInfo.name}留学住宿指南` : `${region}留学住宿指南`;
const description = regionInfo
  ? `${regionInfo.name}留学生公寓/宿舍/homestay 住宿攻略 · ${entries.length} 篇区域指南`
  : `留学住宿指南 · ${entries.length} 篇`;
---

<BaseLayout title={title} description={description}>
  <!-- Region Hero -->
  <section class="relative w-full min-h-[280px] flex items-center justify-center overflow-hidden">
    <img
      src="https://img.ulec.com.cn/unistay/hero-student-apartment.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/40 to-slate-900/75"></div>
    <div class="relative z-10 text-center px-6 py-16 max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl text-white">
        {regionInfo?.name || region} 留学住宿
      </h1>
      <p class="text-slate-200 mt-3 text-lg">
        {entries.length} 篇住宿指南 · 公寓/宿舍/homestay 实测对比
      </p>
    </div>
  </section>

  <!-- Article Grid -->
  <section class="mx-auto max-w-6xl px-6 py-12">
    {
      entries.length === 0 ? (
        <p class="text-center text-muted py-20">该地区暂无文章</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {entries.map((entry) => (
            <ArticleCard entry={entry} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>

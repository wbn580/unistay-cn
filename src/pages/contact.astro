---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = '联系我们 | UniStay 优住';
const description = '联系 UniStay 优住，反馈房源信息、提出合作建议，或咨询留学生住宿查询服务。';
---

<BaseLayout title={title} description={description}>
  <div class="us-wrap" style="padding-block: 2.5rem 1rem;">
    <Breadcrumbs items={[{ label: '首页', href: '/' }, { label: '联系我们' }]} />
  </div>

  <section class="us-wrap" style="padding-block: 0.5rem 4rem; max-width: 46rem;">
    <span class="us-kicker">CONTACT</span>
    <h1 class="us-h" style="font-size: clamp(1.6rem, 4vw, 2.5rem);">联系我们</h1>
    <div style="margin-top: 1.5rem; display: grid; gap: 1.25rem; line-height: 1.9;">
      <p>
        无论是想核实房源信息、反馈页面错误、讨论内容或商业合作，都可以发送邮件给我们。请尽量附上相关页面网址、城市和学校，方便我们快速定位。
      </p>
      <div style="padding: 1.25rem; border: 1px solid var(--color-line); border-radius: var(--radius-card); background: #fff;">
        <h2 style="font-size: 1.15rem;">电子邮件</h2>
        <p style="margin-top: 0.5rem;">
          <a href="mailto:contact@unistay.cn"><strong>contact@unistay.cn</strong></a>
        </p>
        <p style="margin-top: 0.5rem; color: var(--color-muted); font-size: 0.9rem;">
          我们通常会在一个工作日内回复。紧急入住日期请在邮件标题中注明“紧急”。
        </p>
      </div>
      <div>
        <h2 style="font-size: 1.15rem;">房源与评价更正</h2>
        <p style="margin-top: 0.5rem; color: var(--color-muted);">
          价格、房态或评价来源如有变化，请提供公开可核实的来源。我们会复核并更新，但不会接受付费删除差评或修改独立编辑结论。
        </p>
      </div>
      <p style="color: var(--color-muted); font-size: 0.9rem;">
        提交个人信息前，请先阅读<a href="/privacy/">隐私政策</a>。住宿信息与服务边界见<a href="/disclaimer/">免责声明</a>。
      </p>
    </div>
  </section>
</BaseLayout>

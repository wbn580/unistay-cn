---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props as { frontmatter: any };
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="mx-auto max-w-4xl px-4 py-12">
    <p class="text-xs uppercase tracking-wide text-muted">{frontmatter.category}</p>
    <h1 class="font-heading text-3xl md:text-4xl text-primary mt-2 mb-6 leading-tight">{frontmatter.title}</h1>
    <p class="text-base text-muted mb-8">{frontmatter.description}</p>
    <div class="article-prose"><slot /></div>
  </article>
</BaseLayout>